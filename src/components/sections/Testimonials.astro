---
const testimonials = [
  {
    name: "Carlos Mendoza",
    text: "Pensé que había perdido mi laptop, pero la arreglaron el mismo día. Me salvó.",
    rating: 5,
  },
  {
    name: "María García",
    text: "Mi impresora no encendía y estaba desesperada. Vinieron, lo repararon rápido y sin costo oculto. Perfectos.",
    rating: 5,
  },
  {
    name: "Diego López",
    text: "Excelente atención a domicilio. Llegaron rápido, profesionales y solucionaron el problema. Los recomiendo.",
    rating: 5,
  },
];
---

<section
  id="testimonials"
  class="py-20 px-4 sm:px-6 lg:px-8 bg-card/30 border-t border-border"
>
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold font-montserrat mb-4">
        Lo Que Dicen Nuestros Clientes
      </h2>
      <p class="text-foreground/60">
        Miles de clientes satisfechos confían en nuestro servicio
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {
        testimonials.map((testimonial) => (
          <div class="bg-background border border-border/50 rounded-xl p-8">
            <div class="flex gap-1 mb-4">
              {[...Array(testimonial.rating)].map(() => (
                <span class="text-primary text-lg">★</span>
              ))}
            </div>
            <p class="text-foreground/80 mb-4 leading-relaxed">
              "{testimonial.text}"
            </p>
            <div class="font-semibold font-montserrat">{testimonial.name}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
