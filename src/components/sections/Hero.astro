---
import ChevronRight from "../icons/ChevronRight.astro";
import LocationCard from "./LocationCard.astro";
import { siteConfig } from "../../config";
const wa = siteConfig.phone.replace(/\D/g, "");
const address = siteConfig.address;
---

<section class="py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
    <div class="space-y-8">
      <div>
        <div
          class="inline-block bg-primary/10 text-primary px-4 py-2 rounded-lg text-sm font-medium mb-6 border border-primary/30"
        >
          ⚡ Reparación Profesional
        </div>
        <h1
          class="text-4xl sm:text-6xl font-bold font-montserrat leading-tight text-balance"
        >
          ¿Tu equipo de trabajo dejó de funcionar justo cuando más lo necesitas?
        </h1>
        <p class="text-xl text-foreground/70 mt-6 font-semibold">
          Lo reparamos <span class="text-primary">HOY</span> mismo y sin complicaciones.
        </p>
        <p class="text-foreground/60 mt-3 text-sm font-medium">
          Respuesta en minutos • Atención en Lima • Diagnóstico gratis
        </p>
      </div>

      <div class="flex flex-col sm:flex-row gap-4">
        <div
          class="bg-primary text-center text-primary-foreground rounded-lg font-semibold hover:shadow-lg hover:shadow-primary/50 transition-all flex items-center justify-center gap-2 group"
        >
          <a
            href={`https://wa.me/${wa}`}
            target="_blank"
            class="flex items-center gap-2 px-8 py-4"
          >
            Quiero solución inmediata <ChevronRight
              class="w-4 h-4 group-hover:translate-x-1 transition-transform"
            />
          </a>
        </div>
        <div
          class="text-center border border-primary text-primary rounded-lg font-semibold hover:bg-primary/10 transition-colors"
        >
          <a
            href={`https://wa.me/${wa}`}
            target="_blank"
            class="block px-8 py-4"
          >
            Hablar por WhatsApp ahora
          </a>
        </div>
      </div>

      <div class="grid grid-cols-3 gap-4 text-sm">
        <div>
          <div class="text-3xl font-bold text-primary">5+</div>
          <div class="text-foreground/60 text-xs">Años de Experiencia</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-primary">10K+</div>
          <div class="text-foreground/60 text-xs">Equipos Reparados</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-primary">100%</div>
          <div class="text-foreground/60 text-xs">Clientes Satisfechos</div>
        </div>
      </div>
    </div>

    <div class="relative h-full flex flex-col gap-6 md:gap-8">
      <!-- Floating Location Card -->
      <div class="flex items-end justify-end">
        <LocationCard
          title="Nos ubicamos aquí"
          description={address}
          buttonText="Ver ubicación"
          buttonLink="https://www.google.com/maps/place/Shiba+Center/@-11.9599315,-77.0821941,17z/data=!3m1!4b1!4m15!1m8!3m7!1s0x9105cf7127eabcb9:0x3cdcf24f623d3231!2sShiba+Center!8m2!3d-11.9599368!4d-77.0796192!10e1!16s%2Fg%2F11rpt7f7rl!3m5!1s0x9105cf7127eabcb9:0x3cdcf24f623d3231!8m2!3d-11.9599368!4d-77.0796192!16s%2Fg%2F11rpt7f7rl?entry=ttu&g_ep=EgoyMDI2MDUwMi4wIKXMDSoASAFQAw%3D%3D"
        />
      </div>
      <div class="h-96 border border-border/20 rounded-2xl overflow-hidden">
        <img
          src="/repairing-laptop.png"
          alt="Reparación de tecnología"
          class="w-full h-full object-cover opacity-40"
        />
        <div
          class="absolute inset-0 bg-linear-to-t from-background via-transparent to-transparent"
        >
        </div>
      </div>
    </div>
  </div>
</section>
