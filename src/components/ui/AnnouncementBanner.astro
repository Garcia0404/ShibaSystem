---
import Gift from "../icons/Gift.astro";
import ChevronRight from "../icons/ChevronRight.astro";
import { siteConfig } from "../../config";
const wa = siteConfig.phone.replace(/\D/g, "");
---

<div
  id="announcement-banner"
  class="relative z-50 bg-primary text-primary-foreground px-4 py-3"
>
  <div class="max-w-6xl mx-auto flex items-center justify-between gap-4">
    <div class="flex-1"></div>

    <div class="flex items-center gap-3 text-sm font-semibold text-center">
      <Gift class="w-4 h-4 shrink-0" />
      <span>
        🎉 <strong>40% de descuento</strong> en tu primera reparación — Solo por hoy
      </span>
      <a
        target="_blank"
        href={`https://wa.me/${wa}`}
        class="inline-flex items-center gap-1 underline
      underline-offset-2 hover:opacity-80 transition-opacity"
      >
        Aprovecha ahora
        <ChevronRight class="w-4 h-4" />
      </a>
    </div>

    <div class="flex-1 flex justify-end">
      <button
        id="close-banner"
        class="text-primary-foreground/70 hover:text-primary-foreground transition-colors"
        aria-label="Cerrar anuncio"
      >
        ✕
      </button>
    </div>
  </div>

  <script>
    const banner = document.getElementById("announcement-banner");
    const closeBtn = document.getElementById("close-banner");

    closeBtn?.addEventListener("click", () => {
      banner?.remove();
    });
  </script>
</div>
